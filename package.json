{
  "name": "ollama-copilot-bridge",
  "displayName": "Ollama Copilot Bridge",
  "description": "Use Ollama API plus one localhost or VPS Ollama URL in GitHub Copilot Chat in VS Code.",
  "version": "0.0.18",
  "publisher": "AlejandroG",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Noizboy/ollama-copilot-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/Noizboy/ollama-copilot-bridge/issues"
  },
  "homepage": "https://github.com/Noizboy/ollama-copilot-bridge#readme",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#0f62fe",
    "theme": "dark"
  },
  "keywords": [
    "ollama",
    "copilot",
    "language-model",
    "chat",
    "ai",
    "llm"
  ],
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:ollamaCopilot.manage",
    "onCommand:ollamaCopilot.setApiKey",
    "onCommand:ollamaCopilot.testConnection",
    "onCommand:ollamaCopilot.clearApiKey",
    "onCommand:ollamaCopilot.refreshModels",
    "onCommand:ollamaCopilot.diagnostics"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "ollama-bridge",
        "displayName": "Ollama Bridge",
        "managementCommand": "ollamaCopilot.manage"
      }
    ],
    "commands": [
      {
        "command": "ollamaCopilot.manage",
        "title": "Ollama Copilot: Manage"
      },
      {
        "command": "ollamaCopilot.setApiKey",
        "title": "Ollama Copilot: Connect Ollama API"
      },
      {
        "command": "ollamaCopilot.testConnection",
        "title": "Ollama Copilot: Test Connection"
      },
      {
        "command": "ollamaCopilot.clearApiKey",
        "title": "Ollama Copilot: Disconnect Connection"
      },
      {
        "command": "ollamaCopilot.refreshModels",
        "title": "Ollama Copilot: Refresh Models"
      },
      {
        "command": "ollamaCopilot.diagnostics",
        "title": "Ollama Copilot: Diagnostics"
      }
    ],
    "configuration": {
      "title": "Ollama Copilot Bridge",
      "properties": {
        "ollamaCopilot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Ollama language model provider."
        },
        "ollamaCopilot.connectionMode": {
          "type": "string",
          "enum": [
            "cloud",
            "local",
            "remote",
            "custom"
          ],
          "default": "cloud",
          "description": "Primary connection profile used by the bridge."
        },
        "ollamaCopilot.connections": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": [
              "id",
              "label",
              "type",
              "baseUrl"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "cloud",
                  "local",
                  "remote",
                  "custom"
                ]
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "primary": {
                "type": "boolean",
                "default": false
              },
              "baseUrl": {
                "type": "string"
              },
              "openaiCompatiblePath": {
                "type": "string",
                "default": "/v1"
              },
              "requiresApiKey": {
                "type": "boolean",
                "default": false
              }
            }
          },
          "description": "Up to two supported connections: one Ollama API key connection and one localhost/VPS URL connection."
        },
        "ollamaCopilot.baseUrl": {
          "type": "string",
          "default": "https://ollama.com",
          "description": "Base URL for Ollama Cloud or an Ollama-compatible service. Use http://localhost:11434 only if you want local Ollama."
        },
        "ollamaCopilot.openaiCompatiblePath": {
          "type": "string",
          "default": "/v1",
          "description": "OpenAI-compatible path exposed by Ollama."
        },
        "ollamaCopilot.defaultModel": {
          "type": "string",
          "default": "gpt-oss:20b",
          "description": "Fallback model ID used only when a local bridge request does not provide a model or model discovery fails."
        },
        "ollamaCopilot.maxInputTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 1024,
          "description": "Default max input tokens reported for Ollama models."
        },
        "ollamaCopilot.maxOutputTokens": {
          "type": "number",
          "default": 2048,
          "minimum": 128,
          "description": "Default max output tokens reported for Ollama models."
        },
        "ollamaCopilot.requestTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 1000,
          "description": "Timeout for requests sent to Ollama."
        },
        "ollamaCopilot.retryMaxAttempts": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum attempts for retryable Ollama Cloud errors such as 429, 503, and 504."
        },
        "ollamaCopilot.retryBaseDelayMs": {
          "type": "number",
          "default": 1500,
          "minimum": 250,
          "maximum": 30000,
          "description": "Base delay used for exponential backoff between retry attempts."
        },
        "ollamaCopilot.visionModels": {
          "type": "array",
          "default": [
            "kimi-k2.6*"
          ],
          "items": {
            "type": "string"
          },
          "description": "Model IDs or wildcard patterns that should be advertised to VS Code as image-capable when provider metadata omits vision support."
        },
        "ollamaCopilot.pinnedModels": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Model IDs or wildcard patterns that should appear first in the model picker."
        },
        "ollamaCopilot.hiddenModels": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Model IDs or wildcard patterns that should be hidden from the model picker."
        },
        "ollamaCopilot.modelCacheTtlMs": {
          "type": "number",
          "default": 3600000,
          "minimum": 0,
          "description": "How long discovered model metadata is reused before a network refresh is required."
        },
        "ollamaCopilot.metadataConcurrency": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of concurrent metadata requests used while enriching discovered models."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('out',{recursive:true,force:true}); fs.rmSync('out-test',{recursive:true,force:true});\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run clean && tsc -p tsconfig.test.json && node --test out-test/test/modelMetadata.test.js out-test/test/openAiStream.test.js out-test/test/contextUsage.test.js out-test/test/connectionSlots.test.js",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vscode/vsce": "^3.3.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  }
}
